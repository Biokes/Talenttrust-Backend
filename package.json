{
  "name": "talenttrust-backend",
  "version": "0.1.0",
  "description": "TalentTrust API Gateway and services",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "test:unit": "jest src/health.test.ts",
    "test:load": "jest src/tests/load --testTimeout=60000",
    "test:stress": "jest src/tests/stress --testTimeout=120000",
    "test:all": "jest --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.9.0",
    "@types/supertest": "^7.2.0",
    "autocannon": "^8.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
